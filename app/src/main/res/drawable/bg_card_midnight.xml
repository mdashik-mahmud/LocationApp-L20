<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Glass background -->
    <item>
        <shape>
            <solid android:color="#3D6ABD" />
            <corners android:radius="24dp" />
            <stroke
                android:width="1dp"
                android:color="#12E4DF" />
        </shape>
    </item>

    <!-- Subtle top glow overlay -->
    <item android:top="0dp" android:bottom="0dp">
        <shape>
            <gradient
                android:type="linear"
                android:angle="90"
                android:startColor="#BF3656B1"
                android:endColor="#BC000000" />
            <corners android:radius="24dp" />
        </shape>
    </item>

</layer-list>